# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_PUBLISHABLE_KEY=your_publishable_key_here
VITE_SUPABASE_PROJECT_ID=your_project_id_here

# Note: Service key is required for running setup scripts locally
# Keep it securely in your .env file and never commit it to git
SUPABASE_SERVICE_KEY ghg=your_service_role_key_here
